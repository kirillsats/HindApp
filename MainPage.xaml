<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HindApp"
             x:Class="HindApp.MainPage"
             Title="Hind App">

    <VerticalStackLayout Padding="30"
                         Spacing="20"
                         VerticalOptions="Center">

        <Label Text="Добро пожаловать в Hind!"
               FontSize="24"
               HorizontalOptions="Center" />

        <Button Text="Любимые товары"
                FontSize="18"
                Clicked="OnFavoritesClicked" />

        <Button Text="Категории"
                FontSize="18"
                Clicked="OnCategoriesClicked" />

        <Button Text="Сканер"
                FontSize="18"
                Clicked="OnScannerClicked" />

    </VerticalStackLayout>
</ContentPage>
